PORT=8007
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5432/meet_db
REDIS_URL=redis://localhost:6379
BETTER_AUTH_SECRET=your_better_auth_secret_here
AUTH_SERVICE_URL=http://localhost:8001
CLIENT_URL=http://localhost:3000

# Mediasoup — set to the server's LAN IP (or public IP if remote access needed)
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# TURN server — optional, only needed for clients behind symmetric NAT
TURN_SERVER_URL=
TURN_USERNAME=
TURN_PASSWORD=
